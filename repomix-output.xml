                  </tr>

                  {/* ── Expanded row: MT / MX examples side-by-side ── */}
                  {isExpanded && (
                    <tr style={{ background: 'var(--bg-obsidian)' }}>
                      <td colSpan={4} className="px-10 py-6 border-b border-[rgba(255,255,255,0.05)]">
