<file path="frontend/src/app/globals.css">
/* ============================================================
   ISO 20022 Message Explorer — Real Rails Design System
   Background: #030712 (Obsidian Black) — MANDATORY
   Surface:    #0B1117 (Deep Navy Grey)
   Accent 1:   #38BDF8 (Electric Cyan)
   Accent 2:   #818CF8 (Indigo)
   Borders:    #1F2937 (Slate-800)
   ============================================================ */

/* Google Fonts — Inter (UI) + JetBrains Mono (Code) */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap');

@import "tailwindcss";

:root {
  --bg-obsidian: #030712;
  --surface-navy: #0B1117;
  --surface-elevated: #111827;
  --accent-cyan: #38BDF8;
  --accent-cyan-dim: #0EA5E9;
  --accent-cyan-glow: rgba(56, 189, 248, 0.15);
  --accent-indigo: #818CF8;
  --accent-indigo-dim: #6366F1;
  --accent-indigo-glow: rgba(129, 140, 248, 0.15);
  --border-slate: #1F2937;
  --border-active: #38BDF8;
  --text-primary: #F9FAFB;
  --text-secondary: #9CA3AF;
  --text-tertiary: #6B7280;
  --text-accent: #38BDF8;
  --success: #34D399;
  --warning: #FBBF24;
  --error: #F87171;
  --info: #60A5FA;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  color-scheme: dark;
}

body {
  font-family: var(--font-inter), 'Geist Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  background-color: var(--bg-obsidian);
  color: var(--text-primary);
  letter-spacing: -0.01em;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
}

/* === Scrollbar === */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}
::-webkit-scrollbar-track {
  background: var(--bg-obsidian);
}
::-webkit-scrollbar-thumb {
  background: var(--border-slate);
  border-radius: 3px;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--text-tertiary);
}

/* === Glass Card === */
.glass-card {
  background: linear-gradient(135deg, rgba(11, 17, 23, 0.8), rgba(11, 17, 23, 0.6));
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--border-slate);
  border-radius: 12px;
}

.glass-card-hover:hover {
  border-color: rgba(56, 189, 248, 0.3);
  box-shadow: 0 0 0 0.5px rgba(56, 189, 248, 0.3), 0 4px 24px rgba(0, 0, 0, 0.3);
}

/* === Active Glow === */
.cyan-glow {
  box-shadow: 0 0 0 0.5px var(--accent-cyan), 0 0 12px var(--accent-cyan-glow);
}

.indigo-glow {
  box-shadow: 0 0 0 0.5px var(--accent-indigo), 0 0 12px var(--accent-indigo-glow);
}

/* === Animations === */
@keyframes pulse-cyan {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

@keyframes glow-pulse {
  0%, 100% { box-shadow: 0 0 4px var(--accent-cyan-glow); }
  50% { box-shadow: 0 0 16px var(--accent-cyan-glow), 0 0 32px rgba(56, 189, 248, 0.08); }
}

@keyframes fade-in {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slide-in-right {
  from { opacity: 0; transform: translateX(16px); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4px); }
}

@keyframes live-ping {
  0% { transform: scale(1); opacity: 1; }
  75%, 100% { transform: scale(2.2); opacity: 0; }
}

@keyframes scan-line {
  0% { transform: translateY(-100%); opacity: 0; }
  10% { opacity: 0.06; }
  90% { opacity: 0.06; }
  100% { transform: translateY(100vh); opacity: 0; }
}

.animate-fade-in {
  animation: fade-in 0.4s ease-out forwards;
}

.animate-slide-in {
  animation: slide-in-right 0.3s ease-out forwards;
}

.animate-pulse-cyan {
  animation: pulse-cyan 2s ease-in-out infinite;
}

.animate-glow {
  animation: glow-pulse 3s ease-in-out infinite;
}

.animate-float {
  animation: float 3s ease-in-out infinite;
}

.animate-shimmer {
  background: linear-gradient(90deg, transparent 0%, rgba(56, 189, 248, 0.05) 50%, transparent 100%);
  background-size: 200% 100%;
  animation: shimmer 2s linear infinite;
}

.animate-live-ping {
  animation: live-ping 1.4s cubic-bezier(0, 0, 0.2, 1) infinite;
}

/* === Badge Variants === */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 6px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  line-height: 1.6;
}

.badge-cyan {
  background: rgba(56, 189, 248, 0.12);
  color: var(--accent-cyan);
  border: 1px solid rgba(56, 189, 248, 0.2);
}

.badge-indigo {
  background: rgba(129, 140, 248, 0.12);
  color: var(--accent-indigo);
  border: 1px solid rgba(129, 140, 248, 0.2);
}

.badge-success {
  background: rgba(52, 211, 153, 0.12);
  color: var(--success);
  border: 1px solid rgba(52, 211, 153, 0.2);
}

.badge-warning {
  background: rgba(251, 191, 36, 0.12);
  color: var(--warning);
  border: 1px solid rgba(251, 191, 36, 0.2);
}

.badge-error {
  background: rgba(248, 113, 113, 0.12);
  color: var(--error);
  border: 1px solid rgba(248, 113, 113, 0.2);
}

/* === Metric Card === */
.metric-card {
  background: var(--surface-navy);
  border: 1px solid var(--border-slate);
  border-radius: 10px;
  padding: 16px;
  transition: all 0.2s ease;
}

.metric-card:hover {
  border-color: rgba(56, 189, 248, 0.3);
  transform: translateY(-1px);
}

.metric-value {
  font-size: 28px;
  font-weight: 700;
  letter-spacing: -0.03em;
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-indigo));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* === Tab Navigation === */
.tab-nav {
  display: flex;
  gap: 2px;
  padding: 3px;
  background: var(--surface-navy);
  border-radius: 10px;
  border: 1px solid var(--border-slate);
}

.tab-item {
  padding: 8px 16px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.2s ease;
  border: none;
  background: transparent;
  white-space: nowrap;
}

.tab-item:hover {
  color: var(--text-primary);
  background: rgba(56, 189, 248, 0.06);
}

.tab-item.active {
  color: var(--accent-cyan);
  background: rgba(56, 189, 248, 0.1);
  box-shadow: 0 0 0 0.5px rgba(56, 189, 248, 0.3);
}

/* === XML Code Display === */
.xml-display {
  font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
  font-size: 12.5px;
  line-height: 1.7;
  background: var(--bg-obsidian);
  border: 1px solid var(--border-slate);
  border-radius: 8px;
  padding: 16px;
  overflow-x: auto;
  white-space: pre;
  color: var(--text-secondary);
}

.xml-display .xml-tag { color: var(--accent-cyan); }
.xml-display .xml-attr { color: var(--accent-indigo); }
.xml-display .xml-value { color: var(--success); }
.xml-display .xml-comment { color: var(--text-tertiary); font-style: italic; }

/* === Section Headers === */
.section-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.section-header h3 {
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-tertiary);
}

.section-divider {
  flex: 1;
  height: 1px;
  background: var(--border-slate);
}

/* === Button Base === */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
  border: 1px solid transparent;
}

.btn-primary {
  background: linear-gradient(135deg, var(--accent-cyan-dim), var(--accent-cyan));
  color: var(--bg-obsidian);
  font-weight: 600;
}
.btn-primary:hover {
  box-shadow: 0 0 20px var(--accent-cyan-glow);
  transform: translateY(-1px);
}

.btn-secondary {
  background: transparent;
  border-color: var(--border-slate);
  color: var(--text-secondary);
}
.btn-secondary:hover {
  border-color: var(--accent-cyan);
  color: var(--text-primary);
  background: rgba(56, 189, 248, 0.06);
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
  padding: 6px 10px;
}
.btn-ghost:hover {
  color: var(--accent-cyan);
  background: rgba(56, 189, 248, 0.06);
}

/* === Status Indicators === */
.status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  display: inline-block;
}

.status-dot.active {
  background: var(--success);
  box-shadow: 0 0 8px rgba(52, 211, 153, 0.4);
}

.status-dot.pending {
  background: var(--warning);
  box-shadow: 0 0 8px rgba(251, 191, 36, 0.4);
}

.status-dot.error {
  background: var(--error);
  box-shadow: 0 0 8px rgba(248, 113, 113, 0.4);
}

/* === Tree Node (React Flow) === */
.tree-node {
  background: var(--surface-navy);
  border: 1px solid var(--border-slate);
  border-radius: 8px;
  padding: 8px 12px;
  min-width: 120px;
  cursor: pointer;
  transition: all 0.15s ease;
}

.tree-node:hover {
  border-color: var(--accent-cyan);
  box-shadow: 0 0 0 0.5px rgba(56, 189, 248, 0.4), 0 2px 12px rgba(0, 0, 0, 0.3);
}

.tree-node.selected {
  border-color: var(--accent-cyan);
  box-shadow: 0 0 0 0.5px var(--accent-cyan), 0 0 16px var(--accent-cyan-glow);
}

.tree-node .node-tag {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  font-weight: 600;
  color: var(--accent-cyan);
}

.tree-node .node-value {
  font-size: 11px;
  color: var(--text-secondary);
  margin-top: 2px;
  max-width: 160px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* === React Flow overrides === */
.react-flow__background {
  background-color: var(--bg-obsidian) !important;
}

.react-flow__edge-path {
  stroke: var(--border-slate) !important;
  stroke-width: 1.5 !important;
}

.react-flow__minimap {
  background: var(--surface-navy) !important;
  border: 1px solid var(--border-slate) !important;
  border-radius: 8px !important;
}

.react-flow__controls {
  border: 1px solid var(--border-slate) !important;
  border-radius: 8px !important;
  overflow: hidden;
}

.react-flow__controls-button {
  background: var(--surface-navy) !important;
  border-color: var(--border-slate) !important;
  color: var(--text-secondary) !important;
  fill: var(--text-secondary) !important;
}

.react-flow__controls-button:hover {
  background: var(--surface-elevated) !important;
  color: var(--accent-cyan) !important;
  fill: var(--accent-cyan) !important;
}

/* === Responsive === */
@media (max-width: 1024px) {
  .dashboard-layout {
    flex-direction: column;
  }
  .main-stage, .intel-sidebar {
    width: 100% !important;
  }
}

/* === Tooltip === */
.tooltip-content {
  background: var(--surface-elevated);
  border: 1px solid var(--border-slate);
  border-radius: 8px;
  padding: 8px 12px;
  font-size: 12px;
  color: var(--text-primary);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  max-width: 280px;
  z-index: 50;
}

/* Custom scrollbar hiding utility */
.scrollbar-none::-webkit-scrollbar {
  display: none;
}
.scrollbar-none {
  -ms-overflow-style: none;  /* IE and Edge */
  scrollbar-width: none;  /* Firefox */
}
