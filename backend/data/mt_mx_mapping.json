[
  {
    "id": "map-001",
    "mtTag": ":20:",
    "mtName": "Transaction Reference Number",
    "mtFormat": "16x (max 16 alphanumeric)",
    "mxElement": "GrpHdr/MsgId or PmtId/InstrId",
    "mxPath": "/Document/FIToFICstmrCdtTrf/GrpHdr/MsgId",
    "mxFormat": "Max35Text",
    "keyDifference": "MX doubles the character limit (16→35) and splits into multiple IDs for granular tracking",
    "mtExample": ":20:REF20260528001",
    "mxExample": "<MsgId>FNOW-20260528-CTR-001</MsgId>"
  },
  {
    "id": "map-002",
    "mtTag": ":23B:",
    "mtName": "Bank Operation Code",
    "mtFormat": "4!c (CRED, CRTS, SPAY, SPRI, SSTD)",
    "mxElement": "PmtTpInf/SvcLvl/Cd",
    "mxPath": "/Document/FIToFICstmrCdtTrf/CdtTrfTxInf/PmtTpInf/SvcLvl/Cd",
    "mxFormat": "ExternalServiceLevel1Code",
    "keyDifference": "MX uses richer service level codes with more granular payment type classification",
    "mtExample": ":23B:CRED",
    "mxExample": "<SvcLvl><Cd>SEPA</Cd></SvcLvl>"
  },
  {
    "id": "map-003",
    "mtTag": ":32A:",
    "mtName": "Value Date / Currency / Amount",
    "mtFormat": "6!n3!a15d (Date+Currency+Amount combined)",
    "mxElement": "IntrBkSttlmAmt + IntrBkSttlmDt",
    "mxPath": "/Document/FIToFICstmrCdtTrf/CdtTrfTxInf/IntrBkSttlmAmt",
    "mxFormat": "ActiveCurrencyAndAmount + ISODate (separate elements)",
    "keyDifference": "MT combines date+currency+amount in one field. MX separates them into distinct elements with currency as XML attribute",
    "mtExample": ":32A:260528USD2500,00",
    "mxExample": "<IntrBkSttlmAmt Ccy=\"USD\">2500.00</IntrBkSttlmAmt>\n<IntrBkSttlmDt>2026-05-28</IntrBkSttlmDt>"
  },
  {
    "id": "map-004",
    "mtTag": ":33B:",
    "mtName": "Currency / Instructed Amount",
    "mtFormat": "3!a15d",
    "mxElement": "InstdAmt",
    "mxPath": "/Document/FIToFICstmrCdtTrf/CdtTrfTxInf/InstdAmt",
    "mxFormat": "ActiveOrHistoricCurrencyAndAmount",
    "keyDifference": "Direct mapping but MX uses XML attribute for currency instead of inline prefix",
    "mtExample": ":33B:USD2500,00",
    "mxExample": "<InstdAmt Ccy=\"USD\">2500.00</InstdAmt>"
  },
  {
    "id": "map-005",
    "mtTag": ":50K:",
    "mtName": "Ordering Customer (Name & Address)",
    "mtFormat": "4*35x (4 lines max 35 chars each, free-text)",
    "mxElement": "Dbtr (Debtor)",
    "mxPath": "/Document/FIToFICstmrCdtTrf/CdtTrfTxInf/Dbtr",
    "mxFormat": "PartyIdentification — structured fields: Nm, PstlAdr/StrtNm, TwnNm, Ctry, PstCd",
    "keyDifference": "MT uses unstructured free-text (4×35 char lines). MX uses fully structured address fields — critical for AML/sanctions screening",
    "mtExample": ":50K:/445566778899\nAlice Richardson\n1200 Market Street\nPhiladelphia PA 19107 US",
    "mxExample": "<Dbtr><Nm>Alice Richardson</Nm><PstlAdr><StrtNm>1200 Market Street</StrtNm><TwnNm>Philadelphia</TwnNm><Ctry>US</Ctry></PstlAdr></Dbtr>"
  },
  {
    "id": "map-006",
    "mtTag": ":50F:",
    "mtName": "Ordering Customer (Party ID)",
    "mtFormat": "Structured: party ID + 4*35x address lines with line codes",
    "mxElement": "Dbtr + DbtrAcct",
    "mxPath": "/Document/FIToFICstmrCdtTrf/CdtTrfTxInf/Dbtr",
    "mxFormat": "PartyIdentification + CashAccount",
    "keyDifference": ":50F: was MT's attempt at structure using line codes (1/=name, 2/=address). MX replaces this with proper XML elements",
    "mtExample": ":50F:/445566778899\n1/Alice Richardson\n2/1200 Market Street\n3/US/Philadelphia",
    "mxExample": "<Dbtr><Nm>Alice Richardson</Nm></Dbtr><DbtrAcct><Id><Othr><Id>445566778899</Id></Othr></Id></DbtrAcct>"
  },
  {
    "id": "map-007",
    "mtTag": ":52A:",
    "mtName": "Ordering Institution",
    "mtFormat": "BIC (4!a2!a2!c[3!c])",
    "mxElement": "DbtrAgt (Debtor Agent)",
    "mxPath": "/Document/FIToFICstmrCdtTrf/CdtTrfTxInf/DbtrAgt/FinInstnId/BICFI",
    "mxFormat": "BranchAndFinancialInstitutionIdentification",
    "keyDifference": "MX wraps BIC in structured FinInstnId element that can also carry LEI, name, and clearing system member IDs",
    "mtExample": ":52A:CHASUS33",
    "mxExample": "<DbtrAgt><FinInstnId><BICFI>CHASUS33</BICFI><Nm>JPMorgan Chase Bank</Nm></FinInstnId></DbtrAgt>"
  },
  {
    "id": "map-008",
    "mtTag": ":57A:",
    "mtName": "Account With Institution",
    "mtFormat": "BIC (4!a2!a2!c[3!c])",
    "mxElement": "CdtrAgt (Creditor Agent)",
    "mxPath": "/Document/FIToFICstmrCdtTrf/CdtTrfTxInf/CdtrAgt/FinInstnId/BICFI",
    "mxFormat": "BranchAndFinancialInstitutionIdentification",
    "keyDifference": "Same structural upgrade as :52A: — richer institution identification with optional LEI and clearing system IDs",
    "mtExample": ":57A:BOFAUS3N",
    "mxExample": "<CdtrAgt><FinInstnId><BICFI>BOFAUS3N</BICFI><Nm>Bank of America</Nm></FinInstnId></CdtrAgt>"
  },
  {
    "id": "map-009",
    "mtTag": ":59:",
    "mtName": "Beneficiary Customer",
    "mtFormat": "Account + 4*35x (free-text name & address)",
    "mxElement": "Cdtr (Creditor) + CdtrAcct",
    "mxPath": "/Document/FIToFICstmrCdtTrf/CdtTrfTxInf/Cdtr",
    "mxFormat": "PartyIdentification + CashAccount — fully structured",
    "keyDifference": "Same as :50K: upgrade — unstructured free-text replaced with structured XML. Massive improvement for compliance screening",
    "mtExample": ":59:/112233445566\nBob Martinez\n500 Boylston Street\nBoston MA 02116 US",
    "mxExample": "<Cdtr><Nm>Bob Martinez</Nm><PstlAdr><StrtNm>500 Boylston Street</StrtNm><TwnNm>Boston</TwnNm><Ctry>US</Ctry></PstlAdr></Cdtr>"
  },
  {
    "id": "map-010",
    "mtTag": ":70:",
    "mtName": "Remittance Information",
    "mtFormat": "4*35x (max 140 chars across 4 lines)",
    "mxElement": "RmtInf/Ustrd or RmtInf/Strd",
    "mxPath": "/Document/FIToFICstmrCdtTrf/CdtTrfTxInf/RmtInf",
    "mxFormat": "Ustrd: Max140Text or Strd: up to Max9000Text with invoice references",
    "keyDifference": "MX supports 9,000 chars of structured remittance (invoice numbers, tax refs) vs MT's 140-char unstructured limit — 64x capacity increase",
    "mtExample": ":70:Invoice INV-2026-0528\nConsulting Services May 2026",
    "mxExample": "<RmtInf><Ustrd>Invoice INV-2026-0528 - Consulting Services May 2026</Ustrd></RmtInf>"
  },
  {
    "id": "map-011",
    "mtTag": ":71A:",
    "mtName": "Details of Charges",
    "mtFormat": "3!a (BEN, OUR, SHA)",
    "mxElement": "ChrgBr (Charge Bearer)",
    "mxPath": "/Document/FIToFICstmrCdtTrf/CdtTrfTxInf/ChrgBr",
    "mxFormat": "Code: DEBT, CRED, SHAR, SLEV",
    "keyDifference": "Code values renamed for clarity (BEN→CRED, OUR→DEBT, SHA→SHAR) and SLEV added for service-level-defined charging",
    "mtExample": ":71A:SHA",
    "mxExample": "<ChrgBr>SHAR</ChrgBr>"
  },
  {
    "id": "map-012",
    "mtTag": ":72:",
    "mtName": "Sender to Receiver Information",
    "mtFormat": "6*35x (free-text codes like /ACC/, /INS/)",
    "mxElement": "InstrForNxtAgt + InstrForCdtrAgt",
    "mxPath": "/Document/FIToFICstmrCdtTrf/CdtTrfTxInf/InstrForNxtAgt",
    "mxFormat": "Structured instruction codes + InstrInf text",
    "keyDifference": "MT uses free-text code prefixes (/ACC/, /REC/). MX replaces with structured code elements and separate instruction fields per agent",
    "mtExample": ":72:/ACC/Payment for services\n/INS/Please process urgently",
    "mxExample": "<InstrForNxtAgt><Cd>PHOA</Cd><InstrInf>Please process urgently</InstrInf></InstrForNxtAgt>"
  },
  {
    "id": "map-013",
    "mtTag": ":53A:",
    "mtName": "Sender's Correspondent",
    "mtFormat": "BIC",
    "mxElement": "InstgAgt / PrvsInstgAgt",
    "mxPath": "/Document/FIToFICstmrCdtTrf/CdtTrfTxInf/InstgAgt",
    "mxFormat": "BranchAndFinancialInstitutionIdentification",
    "keyDifference": "MX provides richer agent chain tracking with explicit Previous Instructing Agent fields for full audit trail",
    "mtExample": ":53A:IRVTUS3N",
    "mxExample": "<InstgAgt><FinInstnId><BICFI>IRVTUS3N</BICFI></FinInstnId></InstgAgt>"
  },
  {
    "id": "map-014",
    "mtTag": "N/A",
    "mtName": "No MT Equivalent",
    "mtFormat": "Did not exist in MT",
    "mxElement": "UETR",
    "mxPath": "/Document/FIToFICstmrCdtTrf/CdtTrfTxInf/PmtId/UETR",
    "mxFormat": "UUIDv4Text (36 chars)",
    "keyDifference": "Entirely new in ISO 20022 — UUID v4 for global end-to-end tracking. Enables SWIFT gpi transparency. No MT equivalent existed.",
    "mtExample": "—",
    "mxExample": "<UETR>eb6305c9-1f7a-4c3b-8a2d-5e9f1b3c7d4a</UETR>"
  },
  {
    "id": "map-015",
    "mtTag": "N/A",
    "mtName": "No MT Equivalent",
    "mtFormat": "Did not exist in MT",
    "mxElement": "Purp/Cd (Purpose Code)",
    "mxPath": "/Document/FIToFICstmrCdtTrf/CdtTrfTxInf/Purp/Cd",
    "mxFormat": "ExternalPurpose1Code (4 chars)",
    "keyDifference": "New structured purpose codes (SALA, SUPP, TAXS, DIVI, etc.) enable automated categorization and regulatory reporting",
    "mtExample": "—",
    "mxExample": "<Purp><Cd>SUPP</Cd></Purp>"
  }
]
